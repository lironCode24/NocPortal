@{
    ViewData["Title"] = "NOC Dashboards";
    Layout = null;
}
<!DOCTYPE html>
<html lang="he" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/x-icon" href="https://www.menoramivt.co.il/customers-homepage/static/img/favicon.ico">
    <link rel="stylesheet" href="https://cdn.menoramivt.co.il/public/fonts/fonts.css">
    <link rel="stylesheet" href="/assets/fontawesome/css/all.min.css">
    <link rel="stylesheet" href="~/css/noc-portal.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/he.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@latest/dist/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/exceljs@latest/dist/exceljs.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/file-saver@latest/dist/FileSaver.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@latest/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
    <style>
        body {
            font-family: 'Assistant', sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f5f5f5;
        }
    </style>
</head>

<body>
    <div id="userMenuTemplate" style="display:none">
        <div class="user-menu-section">
            <div class="user-info">
                <i class="fas fa-user-circle"></i>
                <span class="user-display-name">
                    היי, @User.FindFirst("DisplayName")?.Value
                </span>

            <div class="user-info">
                <form method="post" action="/Auth/Logout">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-header-logout">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Logout</span>
                    </button>
                </form>
                <button id="backToPortalBtn"
                    style="display:none"
                    class="dashboard-toolbar-btn"
                    onclick="window.location.href='/home'">Back to Home
                </button>
            </div>
    </div>
    <!-- תוכן הדף יוכנס דינמית על ידי DashboardsManager -->
    <script src="~/js/DashboardsManager.js"></script>
</body>

</html>