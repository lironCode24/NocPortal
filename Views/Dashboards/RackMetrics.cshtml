@{
    ViewData["Title"] = "PDU RACKS";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html dir="rtl" lang="he">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PDU RACKS</title>
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <div id="rackMetricsDashboardRoot"></div>

    <script src="/js/DataCenterManager.js"></script>
    <script src="/js/RackMetricsDashboard.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            window.dataCenterManager = new DataCenterManager();
            window.rackMetricsDashboard =
                new RackMetricsDashboard('rackMetricsDashboardRoot');
            window.rackMetricsDashboard.initialize();
        });
    </script>
</body>
</html>