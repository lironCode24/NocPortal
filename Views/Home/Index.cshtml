@{

    ViewData["Title"] = "NOC Portal";

    Layout = null;

}

<!DOCTYPE html>

<html lang="he" dir="rtl">

 

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>@ViewData["Title"]</title>

    <link rel="icon" type="image/x-icon" href=https://www.menoramivt.co.il/customers-homepage/static/img/favicon.ico>

    <link rel="stylesheet" href=https://cdn.menoramivt.co.il/public/fonts/fonts.css>

    <link rel="stylesheet" href="/fontawesome/css/all.min.css">

    <link rel="stylesheet" href="~/css/noc-portal.css">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns/dist/chartjs-adapter-date-fns.bundle.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/he.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>

</head>

 

<body>

 

   <header class="header">

        <div class="container">

        <div class="control-panel">

            <div class="control-panel-header">

                <i class="fas fa-cog"></i>

                <span>ניהול תצוגה</span>

            </div>

            <div class="control-panel-buttons">

                <button class="toggle-all-sections-btn" title="פתח או סגור את כל הסקשנים">

                    <i class="fas fa-expand-alt"></i>

                    <span id="toggleAllText">פתח הכל</span>

                </button>

                <button class="reset-layout-btn" title="אפס סידור סקשנים">

                    <i class="fas fa-undo"></i>

                    <span>אפס סידור</span>

                </button>

            </div>

        </div>

        <div class="header-info">

           

            <div class="logo-section">

                <img src=https://cdn.menoramivt.co.il/public/images/20260113/3ggtc2mkccjb39-menora-logo-ido.png

                    alt="מנורה מבטחים" class="logo">

            </div>

           

            <div class="title-section">

                <div class="title-row">

                    <h1 class="main-title">פורטל חדר מחשב</h1>

                </div>

            </div>

           

            <div class="shift-section">

                <div id="currentShiftIndicator" class="current-shift-indicator">

                    <i class="fas fa-clock"></i>

                    <span>טוען משמרת נוכחית...</span>

                </div>

            </div>

        </div>

        </div>

    </header>

    <div class="alerts-row">

        <!-- Alerts Section -->

        <div class="alerts-section draggable-section" data-section-id="alerts">

            <div class="section-header" onclick="toggleSection('alerts')">

                <i class="fas fa-grip-vertical drag-handle-icon"></i>

                <h2 class="alerts-title">

                    <i class="fas fa-exclamation-triangle"></i>

                    התראות ממערכת ניטור

                </h2>

                <button class="section-toggle-btn" id="alertsToggle">

                    <i class="fas fa-minus"></i>

                </button>

            </div>

            <div class="section-content" id="alertsContent">

                <div class="alerts-container">

                    <div class="alerts-controls">

                        <div class="alerts-search">

                            <input type="text" id="alertSearchInput" placeholder="חיפוש התראות...">

                            <i class="fas fa-search"></i>

                            <button id="clearAlertSearch" class="clear-search-btn" style="display: none;">

                                <i class="fas fa-times"></i>

                            </button>

                        </div>

                         <div class="alerts-filters">

                            <div class="alerts-filter-group">

                                <label>Severity:</label>

                                <div class="filter-buttons-group">

                                    <button class="severity-filter-btn active" data-value="CRITICAL">

                                        <i class="fas fa-bolt"></i> Critical

                                    </button>

                                    <button class="severity-filter-btn active" data-value="MAJOR">

                                        <i class="far fa-exclamation"></i> Major

                                    </button>

                                    <button class="severity-filter-btn active" data-value="UNKNOWN">

                                        <i class="far fa-question-circle"></i> Unknown

                                    </button>

                                </div>

                            </div>

                            <div class="alerts-filter-group">

                                <label>Status:</label>

                                <div class="filter-buttons-group">

                                    <button class="status-filter-btn active" data-value="OPEN">

                                        <i class="fas fa-asterisk"></i> Open

                                    </button>

                                    <button class="status-filter-btn active" data-value="ACK">

                                        <i class="far fa-check-circle"></i> Acknowledge

                                    </button>

                                    <button class="status-filter-btn active" data-value="ASSIGN">

                                        <i class="far fa-user-circle"></i> Assigned

                                    </button>

                                    <button class="status-filter-btn active" data-value="CLOSED">

                                        <i class="fas fa-times-circle"></i> Closed

                                    </button>

                                </div>

                            </div>

                        </div>

                        <div class="alerts-active-filters" id="alertsActiveFilters">

                            <!-- פילטרים פעילים יתווספו כאן דינמית -->

                        </div>

                    </div>

                    <div class="alerts-table-container">

                        <table class="alerts-table">

                            <thead>

                                <tr>

                                    <th>IP Address</th>

                                    <th>Last Update</th>

                                    <th>Notes</th>

                                    <th>Message</th>

                                    <th>Host</th>

                                    <th title="Send Email"><i class="fas fa-envelope"></i></th>

                                    <th>Responsible Team</th>

                                    <th>Date & Time</th>

                                    <th title="Priority"><i class="fas fa-flag"></i></th>

                                    <th title="Severity"><i class="fas fa-triangle-exclamation"></i></th>

                                    <th title="Status"><i class="fas fa-info-circle"></i></th>

                                    <th title="Actions"><i class="fas fa-ellipsis-v"></i></th>

                                </tr>

                            </thead>

                            <tbody id="alertsTableBody">

                                <!-- כאן יתווספו ההתראות באופן דינמי -->

                            </tbody>

                        </table>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="main-content-row">

        <!-- Shifts Column (עמודה ימנית) -->

        <div class="shifts-column" id="shiftsColumn">

            <!-- Shifts Table -->

            <div class="shifts-table-container draggable-section" data-section-id="shifts">

                <div class="section-header" onclick="toggleSection('shifts')">

                    <i class="fas fa-grip-vertical drag-handle-icon"></i>

                    <h2 class="shifts-table-title">

                        <i class="fas fa-calendar"></i>

                        לוח משמרות שבועי

                    </h2>

                    <button class="section-toggle-btn" id="shiftsToggle">

                        <i class="fas fa-minus"></i>

                    </button>

                </div>

                <div class="section-content" id="shiftsContent">

                    <!-- Loading Overlay -->

                    <div class="shifts-loading-overlay" id="shiftsLoadingOverlay">

                        <div class="shifts-loading-content">

                            <i class="fas fa-spinner"></i>

                            <p>שומר שינויים...</p>

                        </div>

                    </div>

                   

                    <!-- Unsaved Changes Warning -->

                    <div class="unsaved-changes-warning" id="unsavedChangesWarning">

                        <i class="fas fa-exclamation-triangle"></i>

                        <span>יש שינויים שלא נשמרו</span>

                    </div>

                     <!-- Edit Controls -->

                    <div class="shifts-edit-controls">

                        <button id="btnSendShiftsEmail" class="btn-edit-shifts btn-send-email-control" onclick="shiftsManager.sendShiftsEmail()">

                            <i class="fas fa-envelope"></i>

                        </button>

                        <button class="btn-edit-shifts" id="btnEditShifts" onclick="shiftsManager.toggleEditMode()" title="עבור למצב עריכה">

                        <i class="fas fa-edit"></i>

                            <!-- <span>ערוך טבלה</span> -->

                        </button>

                        <div class="shifts-controls">

                            <label for="colorModeSelect">סגנון צבעים:</label>

                            <select id="colorModeSelect" onchange="shiftsManager.setColorMode(this.value)">

                                <option value="background">רקע צבעוני</option>

                                <option value="text">טקסט צבעוני</option>

                                <!-- <option value="border">גבול צבעוני</option> -->

                                <option value="gradient">מעבר הדרגתי</option>

                                <option value="dot">נקודה צבעונית</option>

                                <option value="underline">קו תחתון</option>

                                <option value="none">ללא צבעים</option>

                            </select>

                        </div>

                        <button class="btn-save-shifts" id="btnSaveShifts" style="display: none;" onclick="shiftsManager.saveChanges()" title="שמור שינויים">

                            <i class="fas fa-save"></i>

                            <span>שמור שינויים</span>

                        </button>

                       

                        <button class="btn-cancel-edit" id="btnCancelEdit" style="display: none;" onclick="shiftsManager.cancelEdit()" title="בטל עריכה">

                            <i class="fas fa-times"></i>

                            <span>בטל</span>

                        </button>

                       

                        <div class="edit-mode-message" id="editModeMessage" style="display: none;">

                            <i class="fas fa-exclamation-triangle"></i>

                            <span>חשוב! סגור את קובץ המשמרות באקסל לפני שמירה</span>

                        </div>

 

                        <div class="edit-mode-indicator" id="editModeIndicator" style="display: none;">

                            <i class="fas fa-pen"></i>

                            <span>מצב עריכה</span>

                        </div>

                       

                        <div style="flex: 1;"></div>

                       

                        <button class="btn-load-excel" onclick="shiftsManager.loadFromExcel()" title="טען משמרות מעודכנות" style="display: none;">

                            <i class="fas fa-refresh"></i>

                            <span>טען מקובץ</span>

                        </button>

                        <button class="btn-upload-shifts" onclick="event.stopPropagation(); shiftsManager.openUploadModal()" title="העלה קובץ משמרות חדש">

                            <i class="fas fa-upload"></i>

                            <span>העלה קובץ</span>

                        </button>

                        <button class="btn-backup-shifts" onclick="event.stopPropagation(); shiftsManager.openBackupModal()" title="צפה בהיסטורית משמרות">

                            <i class="fas fa-history"></i>

                            <span>היסטוריה</span>

                        </button>

                        <button class="btn-future-shifts" onclick="event.stopPropagation(); shiftsManager.viewFutureShifts()" title="צפה במשמרות עתידיות" style="display: none;">

                            <i class="fas fa-calendar-alt"></i>

                            <span>עתידי</span>

                        </button>

                    </div>

           

                    <div id="shiftsTableContainer">

                        <p style="text-align: center; color: #666;">טוען נתוני משמרות...</p>

                    </div>

                </div>

            </div>

 

            <!-- Phone Directory Section -->

            <div class="phone-directory-section draggable-section" data-section-id="phoneDirectory">

                <div class="section-header" onclick="toggleSection('phoneDirectory')">

                    <i class="fas fa-grip-vertical drag-handle-icon"></i>

                    <h2 class="phone-directory-title">

                        <i class="fas fa-address-book"></i>

                        ספר טלפונים

                    </h2>

                    <button class="section-toggle-btn" id="phoneDirectoryToggle">

                        <i class="fas fa-minus"></i>

                    </button>

                </div>

                <div class="section-content" id="phoneDirectoryContent">

                    <div class="phone-directory-controls">

                        <div class="phone-directory-search">

                            <input type="text" id="phoneDirectorySearchInput" placeholder="חיפוש לפי שם, תפקיד או טלפון...">

                            <i class="fas fa-search"></i>

                            <button class="clear-search-btn"

                                    id="phoneDirectoryClearSearchBtn"

                                    onclick="phoneDirectoryManager.clearSearch()"

                                    style="display: none;"

                                    title="נקה חיפוש">

                                <i class="fas fa-times"></i>

                            </button>

                        </div>

                        <button class="add-contact-btn" onclick="openAddContactModal()">

                            <i class="fas fa-plus"></i>

                            הוסף איש קשר

                        </button>

                    </div>

 

                    <!-- Filters Section -->

                    <div class="employee-tasks-filters collapsible-section">

                        <div class="filters-header" onclick="phoneDirectoryManager.toggleFilterSection()">

                            <div style="display: flex; flex-direction: column; gap: 5px; flex: 1;">

                                <div style="display: flex; align-items: center; gap: 10px;">

                                    <i class="fas fa-sliders-h"></i>

                                    <span style="font-weight: 700; font-size: 1rem; color: white;">סינון ומיון</span>

                                </div>

                                <div id="phoneActiveFiltersDisplay" style="display: none;"></div>

                            </div>

                            <div style="display: flex; align-items: center; gap: 10px;">

                                <button class="clear-filters-btn" onclick="event.stopPropagation(); phoneDirectoryManager.clearFilters()" title="נקה את כל הסינונים">

                                    <i class="fas fa-redo"></i>

                                    אפס

                                </button>

                                <button class="section-collapse-btn" id="phoneFiltersCollapseBtn">

                                    <i class="fas fa-chevron-up"></i>

                                </button>

                            </div>

                        </div>

                       

                        <div class="employee-filters-content collapsible-section" id="phoneFiltersContent">

                            <!-- Combined Filters and Sort Section -->

                            <div class="filters-and-sort-section">

                                <div class="filters-and-sort-row">

                                    <!-- Sort Group with Background -->

                                    <div class="sort-group-wrapper">

                                        <div class="section-label-inline">

                                            <i class="fas fa-sort"></i>

                                            <span>מיון</span>

                                        </div>

                                        <div class="sort-group">

                                            <label>מיין לפי:</label>

                                            <select id="phoneDirectorySort" onchange="phoneDirectoryManager.applyFilters()">

                                                <option value="default">ברירת מחדל</option>

                                                <option value="fullName">שם מלא</option>

                                                <option value="role">תפקיד</option>

                                                <option value="domain">תחום</option>

                                                <option value="department">מחלקה</option>

                                                <option value="team">צוות</option>

                                            </select>

                                        </div>

                                    </div>

 

                                    <!-- Filters Group with Background -->

                                    <div class="filters-group-wrapper">

                                        <div class="section-label-inline">

                                            <i class="fas fa-filter"></i>

                                            <span>סינון</span>

                                        </div>

                                        <div class="filters-inline">

                                            <div class="filter-group">

                                                <label>תחום:</label>

                                                <select id="filterDomain" onchange="phoneDirectoryManager.applyFilters()">

                                                    <option value="">הכל</option>

                                                </select>

                                            </div>

                                           

                                            <div class="filter-group">

                                                <label>מחלקה:</label>

                                                <select id="filterDepartment" onchange="phoneDirectoryManager.applyFilters()">

                                                    <option value="">הכל</option>

                                                </select>

                                            </div>

                                           

                                            <div class="filter-group">

                                                <label>צוות:</label>

                                                <select id="filterTeam" onchange="phoneDirectoryManager.applyFilters()">

                                                    <option value="">הכל</option>

                                                </select>

                                            </div>

                                        </div>

                                    </div>

                                </div>

                            </div>

 

                            <!-- Column Visibility Controls -->

                            <div class="column-visibility-controls" style="margin-top: 15px;">

                                <div class="column-visibility-label">

                                    <i class="fas fa-columns"></i>

                                    <span>עמודות להצגה:</span>

                                </div>

                                <div class="column-checkboxes">

                                    <div class="column-checkbox-item">

                                        <input type="checkbox" id="col-role" checked>

                                        <label for="col-role">תפקיד</label>

                                    </div>

                                    <div class="column-checkbox-item">

                                        <input type="checkbox" id="col-domain" checked>

                                        <label for="col-domain">תחום</label>

                                    </div>

                                    <div class="column-checkbox-item">

                                        <input type="checkbox" id="col-department" checked>

                                        <label for="col-department">מחלקה</label>

                                    </div>

                                    <div class="column-checkbox-item">

                                        <input type="checkbox" id="col-team" checked>

                                        <label for="col-team">צוות</label>

                                    </div>

                                    <div class="column-checkbox-item">

                                        <input type="checkbox" id="col-phone" checked>

                                        <label for="col-phone">טלפון</label>

                                    </div>

                                    <div class="column-checkbox-item">

                                        <input type="checkbox" id="col-extension" checked>

                                        <label for="col-extension">שלוחה</label>

                                    </div>

                                    <div class="column-checkbox-item">

                                        <input type="checkbox" id="col-email" checked>

                                        <label for="col-email">מייל</label>

                                    </div>

                                </div>

                                <button class="reset-columns-btn" onclick="phoneDirectoryManager.resetColumns()">

                                    <i class="fas fa-undo"></i>

                                    אפס

                                </button>

                            </div>

                        </div>

                    </div>

 

                    <div id="phoneDirectoryContainer">

                        <p style="text-align: center; color: #666;">טוען ספר טלפונים...</p>

                    </div>

                </div>

            </div>

 

            <!-- Procedures Section -->

            <div class="procedures-section draggable-section" data-section-id="procedures">

                <div class="section-header" onclick="toggleSection('procedures')">

                    <i class="fas fa-grip-vertical drag-handle-icon"></i>

                    <h2 class="procedures-title">

                        <i class="fas fa-book"></i>

                        נהלים ותהליכים

                    </h2>

                    <button class="section-toggle-btn" id="proceduresToggle">

                        <i class="fas fa-minus"></i>

                    </button>

                </div>

                <div class="section-content" id="proceduresContent">

                    <div class="procedures-header">

                        <div class="procedures-search">

                            <input type="text" id="proceduresSearchInput" placeholder="חיפוש נהלים...">

                            <i class="fas fa-search"></i>

                             <button class="clear-search-btn"

                                    id="clearSearchBtn"

                                    onclick="proceduresManager.clearSearch()"

                                    style="display: none;"

                                    title="נקה חיפוש">

                                <i class="fas fa-times"></i>

                            </button>

                        </div>

                        <button id="collapseAllBtn" class="collapse-all-btn" onclick="proceduresManager.collapseAllFolders()">

                            <i class="fas fa-compress-alt"></i>

                            מזער את כל התיקיות

                        </button>

                        <button class="upload-procedure-btn" onclick="proceduresManager.openUploadModal()">

                            <i class="fas fa-upload"></i>

                            העלה נוהל

                        </button>

                    </div>

                   

                    <!-- Folder View Toggle -->

                    <div class="folder-view-toggle">

                        <button class="folder-view-btn active" id="folderViewBtn" onclick="proceduresManager.switchView('folder')">

                            <i class="fas fa-folder"></i>

                            תצוגת תיקיות

                        </button>

                        <button class="folder-view-btn" id="gridViewBtn" onclick="proceduresManager.switchView('grid')">

                            <i class="fas fa-th"></i>

                            כל הקבצים

                        </button>

                    </div>

                    <div id="proceduresContainer">

                        <p style="text-align: center; color: #666;">טוען נהלים...</p>

                    </div>

                </div>

            </div>

 

            <!-- Team Links Section -->

            <div class="team-links-section draggable-section" data-section-id="teamLinks">

                <div class="section-header" onclick="toggleSection('teamLinks')">

                    <i class="fas fa-grip-vertical drag-handle-icon"></i>

                    <h2 class="team-links-title">

                        <i class="fas fa-link"></i>

                        קישורים שימושיים

                    </h2>

                    <button class="section-toggle-btn" id="teamLinksToggle">

                        <i class="fas fa-minus"></i>

                    </button>

                </div>

                <div class="section-content" id="teamLinksContent">

                    <div class="actions-bar">

                        <div class="search-container">

                            <div class="search-box">

                                <i class="fas fa-search search-icon"></i>

                                <input type="text" id="teamLinksSearchInput" class="search-input" placeholder="חפש קישורים...">

                                <button id="teamLinksClearSearchBtn" class="clear-search-btn" style="display: none;">

                                    <i class="fas fa-times"></i>

                                </button>

                            </div>

                        </div>

                        <div class="team-links-controls">

                            <button class="add-link-btn" onclick="teamLinksManager.openAddLinkModal()">

                                <i class="fas fa-plus"></i>

                                הוסף קישור חדש

                            </button>

                        </div>

                    </div>

                    <!-- Team Links Filters Section -->

                    <div class="employee-tasks-filters collapsible-section filters-section">

                        <div class="filters-header" onclick="teamLinksManager.toggleFilterSection()">

                            <div style="display: flex; flex-direction: column; gap: 5px; flex: 1;">

                                <div style="display: flex; align-items: center; gap: 10px;">

                                    <i class="fas fa-sliders-h"></i>

                                    <span style="font-weight: 700; font-size: 1rem; color: white;">סינון ומיון</span>

                                </div>

                                <div id="teamLinksActiveFiltersDisplay" style="display: none;"></div>

                            </div>

                            <div style="display: flex; align-items: center; gap: 10px;">

                                <button class="clear-filters-btn" id="teamLinksClearFilters" onclick="teamLinksManager.clearFilters()" style="display: none;">

                                    אפס

                                </button>

                                <button class="section-collapse-btn" id="teamLinksFiltersCollapseBtn">

                                    <i class="fas fa-chevron-up"></i>

                                </button>

                            </div>

                        </div>

                       

                        <div class="filters-content employee-filters-content collapsible-section" id="teamLinksFiltersContent">

                            <div class="filters-row">

                                <div class="filter-group">

                                    <label for="filterCategory">קטגוריה:</label>

                                    <select id="filterCategory" class="filter-select">

                                        <option value="">כל הקטגוריות</option>

                                        <!-- יתמלא דינמית -->

                                    </select>

                                </div>

                            </div>

                        </div>

                       

                        <!-- Active Filters Display -->

                        <div id="teamLinksActiveFiltersDisplay" class="active-filters-display" style="display: none;"></div>

                    </div>

 

                    <div id="teamLinksContainer" class="team-links-container">

                        <p style="text-align: center; color: #666;">טוען קישורים...</p>

                    </div>

                </div>

            </div>

 

            <!-- Employee Tasks Section -->

            <div class="employee-tasks-section draggable-section" data-section-id="employeeTasks">

                <div class="section-header" onclick="toggleSection('employeeTasks')">

                    <i class="fas fa-grip-vertical drag-handle-icon"></i>

                    <h2 class="employee-tasks-title">

                        <i class="fas fa-users-cog"></i>

                        משימות לפי עובד

                    </h2>

                    <button class="section-toggle-btn" id="employeeTasksToggle">

                        <i class="fas fa-minus"></i>

                    </button>

                </div>

                <div class="section-content" id="employeeTasksContent">

                    <div class="employee-tasks-controls">

                        <div class="employee-selector">

                            <label for="employeeSelect">בחר עובד:</label>

                            <select id="employeeSelect" class="form-select" onchange="employeeTasksManager.loadEmployeeTasks()">

                                <option value="">בחר עובד...</option>

                                <option value="ALL_EMPLOYEES">כל העובדים</option>

                            </select>

