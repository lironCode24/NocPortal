@model NocPortal.Models.RegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "הרשמה למערכת";
}
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="~/images/logo.png" >
    <link rel="stylesheet" href="https://cdn.menoramivt.co.il/public/fonts/fonts.css">
    <link rel="stylesheet" href="/assets/fontawesome/css/all.min.css">
    <link rel="stylesheet" href="~/css/noc-portal.css">
    <style>
        body {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Rubik', sans-serif;
        }
        .register-container {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 16px;
            padding: 40px;
            width: 100%;
            max-width: 460px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.5);
        }
        .logo-section { text-align: center; margin-bottom: 24px; }
        .logo-section img {
            height: 150px;
            filter: brightness(0.1) invert(0.99);
            margin-right: 50px;
        }
        .register-title {
            color: #fff;
            font-size: 1.4rem;
            font-weight: 700;
            text-align: center;
            margin-bottom: 6px;
        }
        .register-subtitle {
            color: rgba(255,255,255,0.5);
            font-size: 0.85rem;
            text-align: center;
            margin-bottom: 28px;
        }
        .form-group { margin-bottom: 18px; }
        .form-group label {
            display: block;
            color: rgba(255,255,255,0.8);
            font-size: 0.88rem;
            margin-bottom: 7px;
            font-weight: 500;
        }
        .input-wrapper { position: relative; }
        .input-wrapper i {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,0.4);
            font-size: 0.85rem;
        }
        .form-group input,
        .form-group select {
            width: 100%;
            padding: 11px 40px 11px 14px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 8px;
            color: #fff;
            font-size: 0.92rem;
            font-family: inherit;
            transition: border-color 0.2s;
            box-sizing: border-box;
        }
        .form-group select option { background: #1a1a2e; color: #fff; }
        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: #4a9eff;
            background: rgba(255,255,255,0.12);
        }
        .form-group input::placeholder { color: rgba(255,255,255,0.3); }
        .btn-register {
            width: 100%;
            padding: 13px;
            background: linear-gradient(135deg, #28a745, #1e7e34);
            border: none;
            border-radius: 8px;
            color: #fff;
            font-size: 1rem;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            transition: opacity 0.2s;
            margin-top: 6px;
        }
        .btn-register:hover { opacity: 0.9; }
        .alert {
            border-radius: 8px;
            padding: 12px 16px;
            font-size: 0.9rem;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .alert-danger {
            background: rgba(220,53,69,0.2);
            border: 1px solid rgba(220,53,69,0.4);
            color: #ff6b7a;
        }
        .alert-success {
            background: rgba(40,167,69,0.2);
            border: 1px solid rgba(40,167,69,0.4);
            color: #6fcf97;
        }
        .login-link {
            text-align: center;
            margin-top: 22px;
            color: rgba(255,255,255,0.5);
            font-size: 0.9rem;
        }
        .login-link a {
            color: #4a9eff;
            text-decoration: none;
            font-weight: 500;
        }
        .login-link a:hover { text-decoration: underline; }
    </style>
</head>
<body>
<div class="register-container">
    <div class="logo-section">
        <img src="/images/logo.png" alt="Noc Portal Logo">
    </div>

    <h1 class="register-title">הרשמה לפורטל NOC</h1>
    <p class="register-subtitle">לאחר ההרשמה, חשבונך יאושר על ידי מנהל המערכת</p>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle"></i>
            @Model.ErrorMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i>
            @Model.SuccessMessage
        </div>
    }

    @* אם ההרשמה הצליחה - הסתר את הטופס *@
    @if (string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <form method="post" asp-action="Register" asp-controller="Auth">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label for="displayName">שם מלא</label>
                <div class="input-wrapper">
                    <i class="fas fa-id-card"></i>
                    <input type="text"
                           id="displayName"
                           name="DisplayName"
                           placeholder="הכנס שם מלא"
                           value="@Model.DisplayName"
                           required />
                </div>
            </div>

            <div class="form-group">
                <label for="username">שם משתמש</label>
                <div class="input-wrapper">
                    <i class="fas fa-user"></i>
                    <input type="text"
                           id="username"
                           name="Username"
                           placeholder="הכנס שם משתמש (באנגלית)"
                           value="@Model.Username"
                           autocomplete="username"
                           required />
                </div>
            </div>

            <div class="form-group">
                <label for="password">סיסמה</label>
                <div class="input-wrapper">
                    <i class="fas fa-lock"></i>
                    <input type="password"
                           id="password"
                           name="Password"
                           placeholder="לפחות 6 תווים"
                           autocomplete="new-password"
                           required />
                </div>
            </div>

            <div class="form-group">
                <label for="confirmPassword">אימות סיסמה</label>
                <div class="input-wrapper">
                    <i class="fas fa-lock"></i>
                    <input type="password"
                           id="confirmPassword"
                           name="ConfirmPassword"
                           placeholder="הכנס סיסמה שוב"
                           autocomplete="new-password"
                           required />
                </div>
            </div>

            <button type="submit" class="btn-register">
                <i class="fas fa-user-plus"></i>
                שלח בקשת הרשמה
            </button>
        </form>
    }

    <div class="login-link">
        כבר יש לך חשבון?
        <a asp-action="Login" asp-controller="Auth">כניסה למערכת</a>
    </div>

</div>
</body>
</html>